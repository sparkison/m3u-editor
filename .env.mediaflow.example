# MediaFlow Proxy Configuration
# Add these variables to your .env file

# Enable/disable MediaFlow proxy functionality
MEDIAFLOW_PROXY_ENABLED=true

# Microservice configuration (optional)
MEDIAFLOW_MICROSERVICE_ENABLED=false
MEDIAFLOW_MICROSERVICE_URL=http://localhost:3001
MEDIAFLOW_WEBSOCKET_PORT=3002
MEDIAFLOW_MICROSERVICE_TIMEOUT=5

# Proxy behavior settings
MEDIAFLOW_PROXY_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"
MEDIAFLOW_PROXY_TIMEOUT=30
MEDIAFLOW_PROXY_MAX_REDIRECTS=5
MEDIAFLOW_PROXY_VERIFY_SSL=true

# Stream processing settings
MEDIAFLOW_FORCE_PLAYLIST_PROXY=false
MEDIAFLOW_ENABLE_HLS_PROCESSING=true
MEDIAFLOW_ENABLE_FAILOVER=true
MEDIAFLOW_BAD_SOURCE_CACHE_SECONDS=60

# Content routing strategy
MEDIAFLOW_ROUTING_STRATEGY=mediaflow
MEDIAFLOW_PLAYLIST_PROXY_THRESHOLD=1024

# Performance and caching
MEDIAFLOW_MANIFEST_CACHE_TTL=60
MEDIAFLOW_STREAM_INFO_TTL=3600
MEDIAFLOW_BAD_SOURCE_TTL=60

# Logging and monitoring
MEDIAFLOW_LOGGING_ENABLED=true
MEDIAFLOW_LOG_LEVEL=info
MEDIAFLOW_LOG_HEADERS=false
MEDIAFLOW_LOG_BODY=false

# Rate limiting
MEDIAFLOW_RATE_LIMITING_ENABLED=true
MEDIAFLOW_REQUESTS_PER_MINUTE=120
MEDIAFLOW_REQUESTS_PER_HOUR=1000
